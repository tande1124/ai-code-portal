# ============================================================================
# MiniMax 模型（Anthropic 兼容接口）
# ============================================================================
# API Key: https://platform.minimax.io/user-center/basic-information/interface-key
MINIMAX_API_KEY=eyJhbGciOi...

# 可选：自定义 base URL（默认 https://api.minimaxi.com/anthropic/v1）
# ⚠️ 末尾的 /v1 必填：@ai-sdk/anthropic 拼 URL 时只追加 /messages，
# 所以 baseURL 必须以 /v1 结尾，否则会变成 /anthropic/messages → 404。
# 官方文档列出的 server 是 https://api.minimax.io/anthropic（key 实际可能在 .com 上）
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic/v1

# 可选：模型名称（默认 MiniMax-M2.7）
# Anthropic 兼容接口支持的模型：
#   MiniMax-M2.7 / M2.7-highspeed
#   MiniMax-M2.5 / M2.5-highspeed
#   MiniMax-M2.1 / M2.1-highspeed
#   MiniMax-M2
# ⚠️ MiniMax-M3 暂未在 Anthropic 兼容接口提供
# MINIMAX_MODEL=MiniMax-M2.7

# ============================================================================
# Agent 调优
# ============================================================================
# Agent 最大步数（每步 = 一次 LLM 调用 + 工具执行，默认 15）
# AGENT_MAX_STEPS=15

# 工具默认超时（毫秒，默认 15000）
# TOOL_DEFAULT_TIMEOUT=15000
